NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ── Groovia AI (chat assistant) ──────────────────────────────────────────
# LLM goes through OpenRouter (OpenAI-compatible). Server-side only.
OPENROUTER_API_KEY=sk-or-...
# Any chat model you have OpenRouter credits for:
#   anthropic/claude-3.5-sonnet | openai/gpt-4o | google/gemini-2.0-flash-001
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Embeddings for the pgvector knowledge base (RAG). OpenRouter has no embeddings
# endpoint, so this defaults to OpenAI (a few cents for the whole KB). Point it at
# any OpenAI-compatible embeddings provider. Keep 1536-dim (text-embedding-3-small)
# to match the vector(1536) column, or change the column + re-ingest.
EMBEDDINGS_API_KEY=sk-...
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1
# EMBEDDINGS_MODEL=text-embedding-3-small

# Service-role key — used ONLY by the local `npm run ingest` script to write
# kb_documents and read sources. Never ship to the browser / never NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
